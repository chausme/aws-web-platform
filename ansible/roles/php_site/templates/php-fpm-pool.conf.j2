[{{ site.user }}]

user = {{ site.user }}
group = {{ site.user }}

listen = /run/php/php{{ site.php_version }}-{{ site.user }}.sock
listen.owner = {{ site.user }}
listen.group = www-data
listen.mode = 0660

pm = dynamic
pm.max_children = 5
pm.start_servers = 1
pm.min_spare_servers = 1
pm.max_spare_servers = 1
pm.max_requests = 500